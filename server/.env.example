PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/marketplace
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=30d
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLIENT_URL=http://localhost:5173

# M-Pesa Daraja API (Buy Me a Coffee checkout)
# Sandbox test credentials below (Shortcode + Passkey) are Safaricom's PUBLIC
# sandbox values, published in their official docs for anyone to test with.
# You still need your own MPESA_CONSUMER_KEY and MPESA_CONSUMER_SECRET -
# get those free by registering an app at https://developer.safaricom.co.ke
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_sandbox_consumer_key
MPESA_CONSUMER_SECRET=your_sandbox_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# Must be a public HTTPS URL - use ngrok (https://ngrok.com) while testing locally
MPESA_CALLBACK_URL=https://your-ngrok-subdomain.ngrok-free.app/api/mpesa/callback
